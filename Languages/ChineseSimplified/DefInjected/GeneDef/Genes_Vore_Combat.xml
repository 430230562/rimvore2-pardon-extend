  <!-- EN: Fragile gut -->
  <RV2_Gene_QuirkForce_StruggleStrength_Predator_VeryBad.label>脆弱肠胃</RV2_Gene_QuirkForce_StruggleStrength_Predator_VeryBad.label>
  <!-- EN: This pawn is terrible at resisting struggles from its prey. -->
