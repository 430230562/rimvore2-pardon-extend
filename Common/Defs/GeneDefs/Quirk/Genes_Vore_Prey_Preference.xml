<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!-- ========== Prey: Animal Preferences ========== -->
    <GeneDef>
        <defName>RV2_Gene_QuirkForce_DietaryPreference_Prey_Animals_Obsessed</defName>
        <label>Zoogastric obsession</label>
        <description>This pawn adores being prey for animals. If it ever goes missing, make sure to check the bellies of all your livestock, pets, and the wildlife.</description>
        <geneClass>RimVore2.Gene_ForcedHediff</geneClass>
        <iconPath>UI/Icons/Genes/DietaryPreference_Prey_Animals/1</iconPath>
        <modExtensions>
            <li Class="RimVore2.GeneDefExtension_ForcedHediff">
                <hediffs>
                    <li>RV2_Hediff_QuirkForce_DietaryPreference_Prey_Animals_Obsessed</li>
                </hediffs>
                <removeHediffsOnGeneRemoval>true</removeHediffsOnGeneRemoval>
            </li>
        </modExtensions>
        <exclusionTags>
            <li>DietaryPreference_Prey_Animals</li>
        </exclusionTags>
        <displayCategory>RV2_Vore_Prey_Preference</displayCategory>
        <displayOrderInCategory>1</displayOrderInCategory>
        <biostatMet>0</biostatMet>
    </GeneDef>

    <GeneDef>
        <defName>RV2_Gene_QuirkForce_DietaryPreference_Prey_Animals_Likes</defName>
        <label>Zoogastric interest</label>
        <description>This pawn likes being prey for animals. It's thrilling to be subject to the inscrutable whims of a beast, not knowing if it might change its mind about its safety, or when it'll decide to release it.</description>
        <geneClass>RimVore2.Gene_ForcedHediff</geneClass>
        <iconPath>UI/Icons/Genes/DietaryPreference_Prey_Animals/2</iconPath>
        <modExtensions>
            <li Class="RimVore2.GeneDefExtension_ForcedHediff">
                <hediffs>
                    <li>RV2_Hediff_QuirkForce_DietaryPreference_Prey_Animals_Likes</li>
                </hediffs>
                <removeHediffsOnGeneRemoval>true</removeHediffsOnGeneRemoval>
            </li>
        </modExtensions>
        <exclusionTags>
            <li>DietaryPreference_Prey_Animals</li>
        </exclusionTags>
        <displayCategory>RV2_Vore_Prey_Preference</displayCategory>
        <displayOrderInCategory>2</displayOrderInCategory>
        <biostatMet>0</biostatMet>
    </GeneDef>

    <GeneDef>
        <defName>RV2_Gene_QuirkForce_DietaryPreference_Prey_Animals_Neutral</defName>
        <label>Zoogastric ambivalence</label>
        <description>This pawn doesn't mind being prey for animals, but doesn't prefer it either.</description>
        <geneClass>RimVore2.Gene_ForcedHediff</geneClass>
        <iconPath>UI/Icons/Genes/DietaryPreference_Prey_Animals/3</iconPath>
        <modExtensions>
            <li Class="RimVore2.GeneDefExtension_ForcedHediff">
                <hediffs>
                    <li>RV2_Hediff_QuirkForce_DietaryPreference_Prey_Animals_Neutral</li>
                </hediffs>
                <removeHediffsOnGeneRemoval>true</removeHediffsOnGeneRemoval>
            </li>
        </modExtensions>
        <exclusionTags>
            <li>DietaryPreference_Prey_Animals</li>
        </exclusionTags>
        <displayCategory>RV2_Vore_Prey_Preference</displayCategory>
        <displayOrderInCategory>3</displayOrderInCategory>
        <biostatMet>0</biostatMet>
        <biostatCpx>0</biostatCpx>
    </GeneDef>

    <GeneDef>
        <defName>RV2_Gene_QuirkForce_DietaryPreference_Prey_Animals_Dislikes</defName>
        <label>Zoogastric disinterest</label>
        <description>This pawn dislikes being prey for animals. How certain can it be that the beast will listen to demands to be let out?</description>
        <geneClass>RimVore2.Gene_ForcedHediff</geneClass>
        <iconPath>UI/Icons/Genes/DietaryPreference_Prey_Animals/4</iconPath>
        <modExtensions>
            <li Class="RimVore2.GeneDefExtension_ForcedHediff">
                <hediffs>
                    <li>RV2_Hediff_QuirkForce_DietaryPreference_Prey_Animals_Dislikes</li>
                </hediffs>
                <removeHediffsOnGeneRemoval>true</removeHediffsOnGeneRemoval>
            </li>
        </modExtensions>
        <exclusionTags>
            <li>DietaryPreference_Prey_Animals</li>
        </exclusionTags>
        <displayCategory>RV2_Vore_Prey_Preference</displayCategory>
        <displayOrderInCategory>4</displayOrderInCategory>
        <biostatMet>0</biostatMet>
    </GeneDef>

    <GeneDef>
        <defName>RV2_Gene_QuirkForce_DietaryPreference_Prey_Animals_Refuses</defName>
        <label>Zoogastric revulsion</label>
        <description>This pawn hates being prey for animals and will never willingly be consumed by them. It's as disgusting as it is degrading.</description>
        <geneClass>RimVore2.Gene_ForcedHediff</geneClass>
        <iconPath>UI/Icons/Genes/DietaryPreference_Prey_Animals/5</iconPath>
        <modExtensions>
            <li Class="RimVore2.GeneDefExtension_ForcedHediff">
                <hediffs>
                    <li>RV2_Hediff_QuirkForce_DietaryPreference_Prey_Animals_Refuses</li>
                </hediffs>
                <removeHediffsOnGeneRemoval>true</removeHediffsOnGeneRemoval>
            </li>
        </modExtensions>
        <exclusionTags>
            <li>DietaryPreference_Prey_Animals</li>
        </exclusionTags>
        <displayCategory>RV2_Vore_Prey_Preference</displayCategory>
        <displayOrderInCategory>5</displayOrderInCategory>
        <biostatMet>0</biostatMet>
    </GeneDef>
</Defs>