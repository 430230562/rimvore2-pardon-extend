<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/TerrainDef[defName="RV2_FertilizedSoil"]/fertility</xpath>
    <value>
      <fertility>1.6</fertility>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/TerrainDef[defName="RV2_FertilizedSoil"]/costList</xpath>
    <value>
      <costList>
        <RV2_Manufactured_Fertilizer>1</RV2_Manufactured_Fertilizer>
      </costList>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd" MayRequire='Whatif12.RV2Reformers'>
    <xpath>/Defs/ThingDef[defName="Rv2R_ReformerCache_Base"]</xpath>
    <value>
      <researchPrerequisites>
        <li>RV2_Research_Reformer</li>
      </researchPrerequisites>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd" MayRequire='Whatif12.RV2Reformers'>
    <xpath>/Defs/ThingDef[defName="RV2_Reformer_Colony"]</xpath>
    <value>
      <costList>
        <Steel>225</Steel>
        <ComponentIndustrial>4</ComponentIndustrial>
      </costList>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace" MayRequire='Whatif12.RV2Reformers'>
    <xpath>/Defs/ThingDef[defName="RV2_Reformer_Owned"]/costList</xpath>
    <value>
      <costList>
        <Steel>125</Steel>
        <ComponentIndustrial>1</ComponentIndustrial>
      </costList>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd" MayRequire='Whatif12.RV2Reformers'>
    <xpath>/Defs/ThingDef[defName="Rv2_Reformer_Base"]</xpath>
    <value>
      <researchPrerequisites>
        <li>RV2_Research_Reformer</li>
      </researchPrerequisites>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/HediffDef[@Name='LightGenitals_GenitalBase']/stages/li</xpath>
    <value>
      <becomeVisible>false</becomeVisible>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/RecipeDef[@Name='RV2_MakeVoreEnabler_Base']</xpath>
    <value>
      <researchPrerequisites>
        <li>RV2_Research_VoreEnabler</li>
      </researchPrerequisites>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[@Name='RV2_VoreEnabler_Base']/thingCategories</xpath>
    <value>
      <thingCategories>
        <li>RV2_VoreEnablers</li>
      </thingCategories>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[@Name="RV2_VoreEnabler_Base"]/techLevel</xpath>
    <value>
      <techLevel>Industrial</techLevel>
    </value>
  </Operation>

  <Operation Class="PatchOperationRemove">
    <xpath>Defs/RecipeDef[@ParentName="RV2_MakeVoreEnabler_Base"]</xpath>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/ThingDef[@Name="RV2_VoreEnabler_Base"]</xpath>
    <value>
      <recipeMaker>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <workSkill>Crafting</workSkill>
        <effectWorking>Smith</effectWorking>
        <soundWorking>Recipe_Smith</soundWorking>
        <unfinishedThingDef>UnfinishedHealthItemBionic</unfinishedThingDef>
        <researchPrerequisites>
          <li>RV2_Research_VoreEnabler</li>
        </researchPrerequisites>
        <recipeUsers>
          <li>TableMachining</li>
        </recipeUsers>
      </recipeMaker>
      <costList>
        <Gold>1</Gold>
        <Plasteel>10</Plasteel>
        <ComponentSpacer>1</ComponentSpacer>
      </costList>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[@Name='RV2_Product_Consumable_Base']/thingCategories</xpath>
    <value>
      <thingCategories>
        <li>RV2_VoreProduct</li>
      </thingCategories>
    </value>
  </Operation>

</Patch>