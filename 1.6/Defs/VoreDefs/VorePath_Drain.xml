<Defs>
    <RimVore2.VorePathDef ParentName="Drain_Base" MayRequire='Rutrix.RutsRimVoreStuff'>
    <defName>CleavageDrain</defName>
    <label>(Drain) Cleavage-Hold</label>
    <RMBLabel>Cleavage vore</RMBLabel>
    <actionDescription>{PREDATOR} will drain {PREY} through their cleavage</actionDescription>
    <description>Cleavage parasitisim is where the predator swallows the prey into their stomach, where they are drained of their energy. This process is safe, if exhausting.</description>
    <initTale>RV2_VoreInitiation_CleavageDrain</initTale>
    <exitTale>RV2_VoreExit_CleavageDrain</exitTale>
    <voreType>Cleavage</voreType>
    <postVoreMemories>
      <predatorPostVoreSuccess>RV2_PredatorCleavageDrainSuccess</predatorPostVoreSuccess>
      <predatorPostVoreInterrupted>RV2_PredatorCleavageDrainInterrupted</predatorPostVoreInterrupted>
      <preyPostVoreSuccess>RV2_PreyCleavageDrainSuccess</preyPostVoreSuccess>
      <preyPostVoreInterrupted>RV2_PreyCleavageDrainInterrupted</preyPostVoreInterrupted>
    </postVoreMemories>
    <stages>
      <li>Cleavage_Enter</li>
      <li>Stomach_Warmup_Fast</li>
      <li>Stomach_Drain</li>
      <li>Stomach_SoftChurn</li>
      <li>Intestines_SoftProcess</li>
      <li>Anus_Exit</li>
    </stages>
    <defaultRequiredStruggles>60</defaultRequiredStruggles>
  </RimVore2.VorePathDef>

