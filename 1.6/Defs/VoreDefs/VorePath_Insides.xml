<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!-- InsidesDrain见VorePath_Drain -->

    <RimVore2.VorePathDef MayRequire='MamaHorseteeth.RimVore2ExtraVores'>
        <defName>InsidesReform</defName>
        <label>(Reform) membrane inside</label>
        <RMBLabel>Membrane vore</RMBLabel>
        <actionDescription>{PREDATOR} will reform {PREY} inside of them</actionDescription>
        <description>Reformation creates a new pawn inheriting attributes from both original prey and predator</description>
        <initTale>RV2_VoreInitiation_MembraneReform</initTale>
        <exitTale>RV2_VoreExit_MembraneReform</exitTale>
        <voreType>Membrane</voreType>
        <voreGoal>Reform</voreGoal>
        <postVoreMemories>
            <predatorPostVoreSuccess>RV2_PredatorMembraneReformSuccess</predatorPostVoreSuccess>
            <predatorPostVoreInterrupted>RV2_PreyMembraneReformInterrupted</predatorPostVoreInterrupted>
            <preyPostVoreSuccess>RV2_PreyMembraneReformSuccess</preyPostVoreSuccess>
            <preyPostVoreInterrupted>RV2_PreyMembraneReformInterrupted</preyPostVoreInterrupted>
        </postVoreMemories>
        <stages>
            <li>Membrane_Enter</li>
            <li>Insides_Reform</li>
            <li>Membrane_Exit</li>
        </stages>
        <defaultRequiredStruggles>300</defaultRequiredStruggles>
    </RimVore2.VorePathDef>

    <RimVore2.VorePathDef MayRequire='MamaHorseteeth.RimVore2ExtraVores'>
        <defName>InsidesHeal</defName>
        <label>(Heal) membrane inside</label>
        <RMBLabel>Membrane vore</RMBLabel>
        <actionDescription>{PREDATOR} will heal {PREY} in themselves.</actionDescription>
        <description>Healing vore will tend to a pawns wounds and slowly heal their damaged body parts. Healing vore is relatively weak, so if you want to treat a pawn properly, use medicine and a good doctor.</description>
        <voreType>Membrane</voreType>
        <initTale>RV2_VoreInitiation_MembraneHeal</initTale>
        <exitTale>RV2_VoreExit_MembraneHeal</exitTale>
        <voreGoal>Heal</voreGoal>
        <postVoreMemories>
            <predatorPostVoreSuccess>RV2_PredatorMembraneHealSuccess</predatorPostVoreSuccess>
            <preyPostVoreSuccess>RV2_PreyMembraneHealSuccess</preyPostVoreSuccess>
        </postVoreMemories>
        <stages>
            <li>Membrane_Enter</li>
            <li>Insides_Warmup</li>
            <li>Insides_Heal</li>
            <li>Membrane_Exit</li>
        </stages>
        <defaultRequiredStruggles>9</defaultRequiredStruggles>
    </RimVore2.VorePathDef>

    <RimVore2.VorePathDef MayRequire='MamaHorseteeth.RimVore2ExtraVores'
        ParentName="Amalgamate_Base">
        <defName>InsidesAmalgamate</defName>
        <label>(Amalgamate) membrane inside</label>
        <RMBLabel>Membrane vore</RMBLabel>
        <actionDescription>{0} will meld {1} into themselves for storage</actionDescription>
        <description>Inside amalgamation is where the predator reversibly absorbs the prey into themselves for indefinite storage.</description>
        <initTale>RV2_VoreInitiation_InsidesAmalgamate</initTale>
        <exitTale>RV2_VoreExit_InsidesAmalgamate</exitTale>
        <voreType>Membrane</voreType>
        <postVoreMemories>
            <predatorPostVoreSuccess>RV2_PredatorMembraneAmalgamateEnd</predatorPostVoreSuccess>
            <preyPostVoreSuccess>RV2_PreyMembraneAmalgamateEnd</preyPostVoreSuccess>
            <predatorPostVoreInterrupted>RV2_PredatorMembraneAmalgamateEnd</predatorPostVoreInterrupted>
            <preyPostVoreInterrupted>RV2_PreyMembraneAmalgamateEnd</preyPostVoreInterrupted>
        </postVoreMemories>
        <stages>
            <li>Membrane_Enter</li>
            <li>Insides_Contact</li>
            <li>Insides_Amalgamate</li>
            <li>Insides_Reshape</li>
            <li>Membrane_Exit</li>
        </stages>
        <defaultRequiredStruggles>100</defaultRequiredStruggles>
    </RimVore2.VorePathDef>

    <RimVore2.VorePathDef MayRequire='MamaHorseteeth.RimVore2ExtraVores'
        ParentName="Assimilate_Base">
        <defName>InsidesAssimilate</defName>
        <label>(Assimilate) membrane inside</label>
        <RMBLabel>Membrane vore</RMBLabel>
        <actionDescription>{0} will assimilate {1} into themslves</actionDescription>
        <description>Inside assimilation is where the predator permanently absorbs the prey into themslves, feeding the predator</description>
        <initTale>RV2_VoreInitiation_MembraneAssimilate</initTale>
        <exitTale>RV2_VoreExit_MembraneAssimilate</exitTale>
        <voreType>Membrane</voreType>
        <voreProduct>
            <selectableContainers>
                <li>RV2_Container_None</li>
                <li>RV2_Container_Sack</li>
            </selectableContainers>
            <destroyPrey>true</destroyPrey>
        </voreProduct>
        <postVoreMemories>
            <predatorPostVoreSuccess>RV2_PredatorMembraneAssimilateSuccess</predatorPostVoreSuccess>
            <predatorPostVoreInterrupted>RV2_PredatorMembraneAssimilateInterrupted</predatorPostVoreInterrupted>
            <preyPostVoreInterrupted>RV2_PreyMembraneAssimilateInterrupted</preyPostVoreInterrupted>
        </postVoreMemories>
        <stages>
            <li>Membrane_Enter</li>
            <li>Insides_Contact</li>
            <li>Insides_Loosen</li>
            <li>Insides_Assimilate</li>
            <li>Insides_Purge</li>
            <li>Membrane_Dump</li>
        </stages>
        <defaultRequiredStruggles>100</defaultRequiredStruggles>
    </RimVore2.VorePathDef>
</Defs>