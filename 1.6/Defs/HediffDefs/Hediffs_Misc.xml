<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <HediffDef>
        <defName>RV2_FasterRecover</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>faster recover</label>
        <description>This pawn is vored and healed by another pawn.</description>
        <initialSeverity>0.01</initialSeverity>
        <maxSeverity>1.00</maxSeverity>
        <isBad>false</isBad>
        <tendable>false</tendable>
        <priceImpact>false</priceImpact>
        <comps>
            <li Class="PRV2E.HediffCompProperties_DependOnHediff">
                <hediffs>
                    <li>RV2_CurrentlyVored</li>
                </hediffs>
            </li>
        </comps>
        <stages>
            <li>
                <statFactors>
                    <ImmunityGainSpeed>1.05</ImmunityGainSpeed>
                    <InjuryHealingFactor>1.2</InjuryHealingFactor>
                </statFactors>
            </li>
            <li>
                <minSeverity>0.25</minSeverity>
                <statFactors>
                    <ImmunityGainSpeed>1.1</ImmunityGainSpeed>
                    <InjuryHealingFactor>1.55</InjuryHealingFactor>
                </statFactors>
            </li>
            <li>
                <minSeverity>0.5</minSeverity>
                <painFactor>0.90</painFactor>
                <statFactors>
                    <ImmunityGainSpeed>1.2</ImmunityGainSpeed>
                    <InjuryHealingFactor>1.85</InjuryHealingFactor>
                </statFactors>
            </li>
            <li>
                <minSeverity>0.75</minSeverity>
                <painFactor>0.80</painFactor>
                <statFactors>
                    <ImmunityGainSpeed>1.3</ImmunityGainSpeed>
                    <InjuryHealingFactor>2.35</InjuryHealingFactor>
                </statFactors>
            </li>
            <li>
                <minSeverity>0.90</minSeverity>
                <painFactor>0.70</painFactor>
                <socialFightChanceFactor>0.55</socialFightChanceFactor>
                <statFactors>
                    <ImmunityGainSpeed>1.35</ImmunityGainSpeed>
                    <InjuryHealingFactor>2.65</InjuryHealingFactor>
                </statFactors>
            </li>
            <li>
                <minSeverity>0.95</minSeverity>
                <painFactor>0.60</painFactor>
                <statFactors>
                    <ImmunityGainSpeed>1.4</ImmunityGainSpeed>
                    <InjuryHealingFactor>3</InjuryHealingFactor>
                </statFactors>
                <regeneration>20</regeneration>
            </li>
        </stages>
    </HediffDef>

    <HediffDef>
        <defName>RV2_Regression</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>regression</label>
        <description>This pawn is in other pawn womb and regressed.\n This hediff can't let the age
            of a pawn decrease below the age of adult.</description>
        <initialSeverity>0.10</initialSeverity>
        <maxSeverity>1.00</maxSeverity>
        <isBad>false</isBad>
        <tendable>false</tendable>
        <priceImpact>false</priceImpact>
        <comps>
            <li Class="PRV2E.HediffCompProperties_Regression">
                <RegressionStrength>30</RegressionStrength>
                <limitMinAge>true</limitMinAge>
            </li>
            <li Class="PRV2E.HediffCompProperties_DependOnHediff">
                <hediffs>
                    <li>RV2_CurrentlyVored</li>
                </hediffs>
            </li>
            <li Class="HediffCompProperties_DisappearsOnDeath" />
        </comps>
    </HediffDef>

    <HediffDef>
        <defName>RV2_UnlimitedRegression</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>unlimited regression</label>
        <description>This pawn is being reformed in other pawn womb.\n This hediff may let the age
            of a pawn decrease to zero.\n\n In some degrees,age decreasing can be regard as a type
            of reform damage.</description>
        <initialSeverity>0.10</initialSeverity>
        <maxSeverity>6.00</maxSeverity>
        <isBad>false</isBad>
        <tendable>false</tendable>
        <priceImpact>false</priceImpact>
        <comps>
            <li Class="PRV2E.HediffCompProperties_Regression">
                <RegressionStrength>40</RegressionStrength>
                <limitMinAge>false</limitMinAge>
            </li>
            <li Class="PRV2E.HediffCompProperties_DependOnHediff">
                <hediffs>
                    <li>RV2_CurrentlyVored</li>
                </hediffs>
            </li>
            <li Class="HediffCompProperties_DisappearsOnDeath" />
        </comps>
    </HediffDef>

