<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <HediffDef ParentName="AddedBodyPartBase">
        <defName>RV2_DigestionAdjuster</defName>
        <label>digestion adjuster</label>
        <labelNoun>a digestion adjuster</labelNoun>
        <description>An implant-derived quirk that enhances predation efficiency at the cost of mobility. As a predator, the pawn gains 2.5x nutrition from prey and digests them at 2x speed, suffers less 20% reduction in movement capacity.</description>
        <descriptionHyperlinks>
            <ThingDef>RV2_DigestionAdjuster</ThingDef>
        </descriptionHyperlinks>
        <spawnThingOnRemoved>RV2_DigestionAdjuster</spawnThingOnRemoved>
        <addedPartProps>
            <solid>true</solid>
            <partEfficiency>1</partEfficiency>
            <betterThanNatural>true</betterThanNatural>
        </addedPartProps>
        <comps>
            <li Class="RimVore2.HediffCompProperties_QuirkForcer">
                <quirks>
                    <li>RV2_DigestionAdjuster</li>
                    <li>ItemDamage_Spotless</li>
                </quirks>
            </li>
        </comps>
    </HediffDef>
</Defs>