<?xml version="1.0" encoding="utf-8" ?>

<!-- 这不是一个高效的方法 -->
<Defs>
<!-- 机动性 -->
    <HediffDef ParentName="RV2_VoreEnabledPart_Base">
        <defName>RV2_Hediff_QuirkForce_Cheat_Hammerspace</defName>
        <label>Hammerspace</label>
        <description>This pawn's body compresses its prey down to an incredible degree.</description>
        <comps>
            <li Class="RimVore2.HediffCompProperties_QuirkForcer">
                <quirks>
                    <li>Cheat_Hammerspace</li>
                </quirks>
            </li>
        </comps>
    </HediffDef>

    <HediffDef ParentName="RV2_VoreEnabledPart_Base">
        <defName>RV2_Hediff_QuirkForce_Mobility_Godlike</defName>
        <label>Godlike Mobility</label>
        <description>This pawn makes walking around with the weight of multiple full grown people hanging off of it look effortless.</description>
        <comps>
            <li Class="RimVore2.HediffCompProperties_QuirkForcer">
                <quirks>
                    <li>Mobility_Godlike</li>
                </quirks>
            </li>
        </comps>
    </HediffDef>

    <HediffDef ParentName="RV2_VoreEnabledPart_Base">
        <defName>RV2_Hediff_QuirkForce_Mobility_VeryGood</defName>
        <label>Acrobatic</label>
        <description>This pawn moves freely while full of prey, as though its belly wasn't there.</description>
        <comps>
            <li Class="RimVore2.HediffCompProperties_QuirkForcer">
                <quirks>
                    <li>Mobility_VeryGood</li>
                </quirks>
            </li>
        </comps>
    </HediffDef>

    <HediffDef ParentName="RV2_VoreEnabledPart_Base">
        <defName>RV2_Hediff_QuirkForce_Mobility_Good</defName>
        <label>Nimble</label>
        <description>This pawn knows how to keep its balance with a bulging belly.</description>
        <comps>
            <li Class="RimVore2.HediffCompProperties_QuirkForcer">
                <quirks>
                    <li>Mobility_Good</li>
                </quirks>
            </li>
        </comps>
    </HediffDef>

    <HediffDef ParentName="RV2_VoreEnabledPart_Base">
        <defName>RV2_Hediff_QuirkForce_Mobility_Normal</defName>
        <label>Normal mobility</label>
        <description>This pawn is affected by its prey's weight like anyone else.</description>
        <comps>
            <li Class="RimVore2.HediffCompProperties_QuirkForcer">
                <quirks>
                    <li>Mobility_Normal</li>
                </quirks>
            </li>
        </comps>
    </HediffDef>

    <HediffDef ParentName="RV2_VoreEnabledPart_Base">
        <defName>RV2_Hediff_QuirkForce_Mobility_Bad</defName>
        <label>Clumsy</label>
        <description>This pawn is unsteady with a big belly and prone to tumbling whenever its prey decide to kick around.</description>
        <comps>
            <li Class="RimVore2.HediffCompProperties_QuirkForcer">
                <quirks>
                    <li>Mobility_Bad</li>
                </quirks>
            </li>
        </comps>
    </HediffDef>

    <HediffDef ParentName="RV2_VoreEnabledPart_Base">
        <defName>RV2_Hediff_QuirkForce_Mobility_VeryBad</defName>
        <label>Sluggish</label>
        <description>This pawn can barely stay on its feet with a big, round belly, let alone jog around.</description>
        <comps>
            <li Class="RimVore2.HediffCompProperties_QuirkForcer">
                <quirks>
                    <li>Mobility_VeryBad</li>
                </quirks>
            </li>
        </comps>
    </HediffDef>

    <!-- 容量 -->

    <HediffDef ParentName="RV2_VoreEnabledPart_Base">
        <defName>RV2_Hediff_QuirkForce_Cheat_InfiniteCapacity</defName>
        <label>Infinite Capacity</label>
        <description>This pawn doesn't know the meaning of the word "full". There's always room for more prey.</description>
        <comps>
            <li Class="RimVore2.HediffCompProperties_QuirkForcer">
                <quirks>
                    <li>Cheat_InfiniteCapacity</li>
                </quirks>
            </li>
        </comps>
    </HediffDef>

    <HediffDef ParentName="RV2_VoreEnabledPart_Base">
        <defName>RV2_Hediff_QuirkForce_StorageCapacity_Godlike</defName>
        <label>Godlike Capacity</label>
        <description>This pawn's skin is supernaturally stretchy, able to expand to sizes that defy all logic and reason.</description>
        <comps>
            <li Class="RimVore2.HediffCompProperties_QuirkForcer">
                <quirks>
                    <li>StorageCapacity_Godlike</li>
                </quirks>
            </li>
        </comps>
    </HediffDef>

    <HediffDef ParentName="RV2_VoreEnabledPart_Base">
        <defName>RV2_Hediff_QuirkForce_StorageCapacity_VeryGood</defName>
        <label>Cavernous</label>
        <description>This pawn can stuff itself silly with prey and still have room for more, though even this pawn has limits.</description>
        <comps>
            <li Class="RimVore2.HediffCompProperties_QuirkForcer">
                <quirks>
                    <li>StorageCapacity_VeryGood</li>
                </quirks>
            </li>
        </comps>
    </HediffDef>

    <HediffDef ParentName="RV2_VoreEnabledPart_Base">
        <defName>RV2_Hediff_QuirkForce_StorageCapacity_Good</defName>
        <label>Stretchy</label>
        <description>This pawn can stretch to fit more prey than the average predator.</description>
        <comps>
            <li Class="RimVore2.HediffCompProperties_QuirkForcer">
                <quirks>
                    <li>StorageCapacity_Good</li>
                </quirks>
            </li>
        </comps>
    </HediffDef>

    <HediffDef ParentName="RV2_VoreEnabledPart_Base">
        <defName>RV2_Hediff_QuirkForce_StorageCapacity_Normal</defName>
        <label>Normal capacity</label>
        <description>This pawn can fit as many prey as anyone else.</description>
        <comps>
            <li Class="RimVore2.HediffCompProperties_QuirkForcer">
                <quirks>
                    <li>StorageCapacity_Normal</li>
                </quirks>
            </li>
        </comps>
    </HediffDef>

    <HediffDef ParentName="RV2_VoreEnabledPart_Base">
        <defName>RV2_Hediff_QuirkForce_StorageCapacity_Bad</defName>
        <label>Tight</label>
        <description>This pawn struggles to fit as many prey inside itself as most of its predatory peers can.</description>
        <comps>
            <li Class="RimVore2.HediffCompProperties_QuirkForcer">
                <quirks>
                    <li>StorageCapacity_Bad</li>
                </quirks>
            </li>
        </comps>
    </HediffDef>

    <HediffDef ParentName="RV2_VoreEnabledPart_Base">
        <defName>RV2_Hediff_QuirkForce_StorageCapacity_VeryBad</defName>
        <label>Claustrophobic</label>
        <description>This pawn struggles with a lack of capacity for prey and fills up fast.</description>
        <comps>
            <li Class="RimVore2.HediffCompProperties_QuirkForcer">
                <quirks>
                    <li>StorageCapacity_VeryBad</li>
                </quirks>
            </li>
        </comps>
    </HediffDef>
</Defs>