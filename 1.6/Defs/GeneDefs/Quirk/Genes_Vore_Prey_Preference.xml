    <!-- ========== Prey: Animal Preferences ========== -->
    <GeneDef>
        <defName>RV2_Gene_QuirkForce_DietaryPreference_Prey_Animals_Obsessed</defName>
        <label>Zoogastric obsession</label>
        <description>This pawn adores being prey for animals. If it ever goes missing, make sure to check the bellies of all your livestock, pets, and the wildlife.</description>
        <geneClass>RimVore2.Gene_ForcedHediff</geneClass>
        <iconPath>UI/Icons/Genes/DietaryPreference_Prey_Animals/1</iconPath>
        <modExtensions>
            <li Class="RimVore2.GeneDefExtension_ForcedHediff">
                <hediffs>
                    <li>RV2_Hediff_QuirkForce_DietaryPreference_Prey_Animals_Obsessed</li>
                </hediffs>
                <removeHediffsOnGeneRemoval>true</removeHediffsOnGeneRemoval>
            </li>
        </modExtensions>
        <exclusionTags>
            <li>DietaryPreference_Prey_Animals</li>
        </exclusionTags>
        <displayCategory>RV2_Vore_Prey_Preference</displayCategory>
        <displayOrderInCategory>1</displayOrderInCategory>
        <biostatMet>0</biostatMet>
    </GeneDef>

