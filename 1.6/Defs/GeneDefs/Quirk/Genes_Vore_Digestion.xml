            </li>
        </modExtensions>
        <exclusionTags>
            <li>DigestionResistance</li>
        </exclusionTags>
        <displayCategory>RV2_Vore_Digestion</displayCategory>
        <displayOrderInCategory>1</displayOrderInCategory>
        <biostatMet>-2</biostatMet>
    </GeneDef>

    <GeneDef>
        <defName>RV2_Gene_QuirkForce_DigestionResistance_Good</defName>
