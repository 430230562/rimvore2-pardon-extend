<?xml version="1.0" encoding="utf-8" ?>
<Defs>
 <!-- 消化阻力 -->
    <GeneDef>
        <defName>RV2_Gene_QuirkForce_Cheat_Indigestible</defName>
        <label>Indigestible</label>
        <description>This pawn is immune to digestion. Not immune to bullets, blades, explosions, or even external acid sprays, but certainly immune to digestion.</description>
        <geneClass>RimVore2.Gene_ForcedHediff</geneClass>
        <iconPath>UI/Icons/Genes/DigestionResistance/6</iconPath>
        <modExtensions>
            <li Class="RimVore2.GeneDefExtension_ForcedHediff">
                <hediffs>
                    <li>RV2_Hediff_QuirkForce_Cheat_Indigestible</li>
                </hediffs>
                <removeHediffsOnGeneRemoval>true</removeHediffsOnGeneRemoval>
            </li>
        </modExtensions>
        <exclusionTags>
            <li>DigestionResistance</li>
        </exclusionTags>
        <displayCategory>RV2_Vore_Digestion</displayCategory>
        <displayOrderInCategory>0</displayOrderInCategory>
        <biostatMet>0</biostatMet>
        <biostatArc>2</biostatArc>
    </GeneDef>

    <GeneDef>
        <defName>RV2_Gene_QuirkForce_DigestionResistance_VeryGood</defName>
        <label>Acid-proof</label>
        <description>This pawn is very difficult to digest. Not impossible, but it'll take a while; about four times as long as most prey.</description>
        <geneClass>RimVore2.Gene_ForcedHediff</geneClass>
        <iconPath>UI/Icons/Genes/DigestionResistance/5</iconPath>
