<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <GeneDef>
        <defName>RV2_Gene_QuirkForce_ProposalFrequency_None</defName>
        <label>Vore apathy</label>
        <description>This pawn does not care enough about vore to initiate vore proposals on its own. It has no qualms about being told to do it, though.</description>
        <geneClass>RimVore2.Gene_ForcedHediff</geneClass>
        <iconPath>UI/Icons/Genes/ProposalFrequency/1</iconPath>
        <modExtensions>
            <li Class="RimVore2.GeneDefExtension_ForcedHediff">
                <hediffs>
                    <li>RV2_Hediff_QuirkForce_ProposalFrequency_None</li>
                </hediffs>
                <removeHediffsOnGeneRemoval>true</removeHediffsOnGeneRemoval>
            </li>
        </modExtensions>
        <exclusionTags>
            <li>ProposalFrequency</li>
        </exclusionTags>
        <displayCategory>RV2_Vore_Proposals</displayCategory>
        <displayOrderInCategory>1</displayOrderInCategory>
        <biostatMet>0</biostatMet>
    </GeneDef>

